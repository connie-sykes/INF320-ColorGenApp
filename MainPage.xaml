<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyMauiApp.MainPage">

    <!-- Fondo de la página -->
    <ContentPage.Background>
        <SolidColorBrush x:Name="FondoColor" Color="#FFFFFF" />
    </ContentPage.Background>

    <VerticalStackLayout Padding="40" Spacing="20" VerticalOptions="Center">

        <!-- Muestra el hex generado -->
        <Label x:Name="LabelHex"
               Text="#FFFFFF"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <!-- Sliders manuales RGB -->
        <Label Text="Rojo" HorizontalOptions="Center" />
        <Slider x:Name="SliderR" Minimum="0" Maximum="255" Value="255"
                ValueChanged="OnSliderCambiado" />

        <Label Text="Verde" HorizontalOptions="Center" />
        <Slider x:Name="SliderG" Minimum="0" Maximum="255" Value="255"
                ValueChanged="OnSliderCambiado" />

        <Label Text="Azul" HorizontalOptions="Center" />
        <Slider x:Name="SliderB" Minimum="0" Maximum="255" Value="255"
                ValueChanged="OnSliderCambiado" />

        <!-- Botón color aleatorio -->
        <Button Text="Color Aleatorio"
                Clicked="OnColorAleatorioClicked" />

        <!-- Botón copiar hex -->
        <Button Text="Copiar Hex"
                Clicked="OnCopiarHexClicked" />

    </VerticalStackLayout>

</ContentPage>
